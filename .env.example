# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require&pgbouncer=true"  # Pooled connection for general use
DIRECT_URL="postgresql://user:password@host:port/db?sslmode=require"  # Direct connection for migrations

# Authentication
NEXTAUTH_URL="http://localhost:3000"  # Development: localhost, Production: your domain
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"  # Use different values for each environment

# External APIs
OPENWEATHER_API_KEY=""  # OpenWeather API key
RESEND_API_KEY=""      # Resend API key (use test key for development/preview)
CLAUDE_API_KEY=""      # Claude API key

# Environment-specific settings
NODE_ENV="development" # development, production, or preview